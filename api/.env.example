# JWT Secret for authentication
# Generate a strong random string using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-key-here

# Admin password
# Generate a strong password using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_PASSWORD=your-admin-password-here

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://hkgdl.ddns.net

# SSL Certificate configuration (for HTTPS)
# Generate certificates using: ./generate-certs.sh
SSL_KEY_PATH=./certs/key.pem
SSL_CERT_PATH=./certs/cert.pem

# HTTPS Port (default: 19132 - same as HTTP since that's what's forwarded)
HTTPS_PORT=19132

# Trust proxy (set to 'true' if behind a reverse proxy like nginx)
TRUST_PROXY=false